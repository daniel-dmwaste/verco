# Verco — environment variable manifest
#
# Copy to .env.local for development. Never commit .env.local.
# Real values live in:
#   - GitHub Actions secrets (for CI + build-time baking)
#   - Coolify env panel       (for Next.js runtime on prod)
#   - `supabase secrets set`  (for Edge Functions)
#
# ---------------------------------------------------------------
# PUBLIC — baked into the Next.js client bundle at `next build`
# ---------------------------------------------------------------
# These are exposed in the browser. Never put secrets here.
# In Docker, they are passed as --build-arg and written to ENV
# in the builder stage (see Dockerfile). Changing them requires
# a rebuild; setting them in Coolify's runtime env does nothing.

NEXT_PUBLIC_SUPABASE_URL=https://tfddjmplcizfirxqhotv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Populated by CI at build time from the commit SHA.
# Surfaced by /api/health so we can confirm the deployed commit.
NEXT_PUBLIC_GIT_SHA=

# ---------------------------------------------------------------
# SERVER-ONLY — set in Coolify env panel (Next.js runtime)
# ---------------------------------------------------------------
# Currently none. All server secrets live in Edge Functions.
# Coolify only needs: NODE_ENV=production, PORT=3000, HOSTNAME=0.0.0.0.
# If a server-only var is added later, document it here and set it
# in Coolify — never commit the value.

# ---------------------------------------------------------------
# EDGE FUNCTION ONLY — set via `supabase secrets set --project-ref tfddjmplcizfirxqhotv`
# ---------------------------------------------------------------
# These MUST NEVER appear in the Next.js image, in Coolify env,
# or in any file under src/ (CLAUDE.md §16 red line #3).
# Listed here so the env contract is discoverable in one place.
#
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# GOOGLE_PLACES_API_KEY=
